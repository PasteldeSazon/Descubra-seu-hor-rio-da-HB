      };

      function mostrarHorario() {
        const diaEscolhido = document.getElementById("dia").value;
        const listaAulas = horarios[diaEscolhido];
        const container = document.getElementById("horario");
        if (container) {
          container.innerHTML = "<h2>Horário de " + diaEscolhido + ":</h2>";
          if (listaAulas) {
            let htmlGerado = "<ul>";
            listaAulas.forEach(aula => {
              let infoProfessor = aula.professor ? " - Prof. " + aula.professor : (aula.professora ? " - Prof. " + aula.professora : "");
              htmlGerado += "<li><strong>" + aula.hora + "</strong>: " + aula.materia + infoProfessor + "</li>";
            });
            htmlGerado += "</ul>";
            container.innerHTML += htmlGerado;
          } else {
            container.innerHTML += "<p>Nenhum horário encontrado.</p>";
          }
        }
      }