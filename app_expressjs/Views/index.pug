doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Descubra seu horário escolar da HB
    link(rel='stylesheet', href='https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css')
  
  body.container.mt-4
    h1 Descubra seu horário escolar da HB
    p Olá, seja bem-vindo ao site que vai te ajudar!
    p Selecione o dia da semana para ver as aulas programadas.
    
    .form-group
      label(for="dia") Escolha o dia da semana:
      select.form-control#dia(name="dia")
        option(value="Segunda-feira") Segunda-feira
        option(value="Terça-feira") Terça-feira
        option(value="Quarta-feira") Quarta-feira
        option(value="Quinta-feira") Quinta-feira
        option(value="Sexta-feira") Sexta-feira

    button.btn.btn-primary(onclick="mostrarHorario()") Mostrar Horário

    div#horario.mt-4

    //- Estrutura do Modal
    #modalAgradecimento.modal.fade(tabindex='-1' role='dialog')
      .modal-dialog(role='document')
        .modal-content
          .modal-header
            h5.modal-title Obrigado por usar a ferramenta!
          .modal-body
            p Obrigado por usar esta ferramenta.
            p Clique em OK para preencher o formulário e me ajudar a saber quem usou o site.
          .modal-footer
            button.btn.btn-secondary(type='button' data-dismiss='modal') Cancelar
            a.btn.btn-primary(href='/create') OK

    script(src='https://code.jquery.com/jquery-3.6.0.min.js')
    script(src='https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js')

