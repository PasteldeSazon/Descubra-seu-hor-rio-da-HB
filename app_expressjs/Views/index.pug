      function mostrarHorario() {
        const diaEscolhido = document.getElementById("dia").value;
        const listaAulas = horarios[diaEscolhido];
        const container = document.getElementById("horario");
        
        if (container) {
          if (listaAulas) {
            container.innerHTML = "<h2>Horário de " + diaEscolhido + ":</h2>";
            let htmlGerado = "<ul>";
            listaAulas.forEach(aula => {
              let prof = aula.professor || aula.professora || "";
              htmlGerado += "<li><strong>" + aula.hora + "</strong>: " + aula.materia + (prof ? " - " + prof : "") + "</li>";
            });
            htmlGerado += "</ul>";
            container.innerHTML += htmlGerado;

            // Lógica de Memória: verifica se já exibiu o modal antes
            const jaExibiu = localStorage.getItem('jaPreencheu');
            if (!jaExibiu) {
              setTimeout(function() {
                $('#modalAgradecimento').modal('show');
                localStorage.setItem('jaPreencheu', 'true'); // Grava a informação no navegador
              }, 7000);
            }
          } else {
            container.innerHTML = "<h2>Selecione um dia válido</h2>";
          }
        }
      }